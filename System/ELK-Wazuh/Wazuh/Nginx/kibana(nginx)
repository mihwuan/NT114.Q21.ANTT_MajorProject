# /etc/nginx/sites-available/kibana 
# Rate limiting
limit_req_zone $binary_remote_addr zone=kibana_limit:10m rate=10r/s;

server {
    listen 80;
    server_name _;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2 default_server;
    server_name _;

    ssl_certificate     /etc/nginx/ssl/nginx.crt;
    ssl_certificate_key /etc/nginx/ssl/nginx.key;

    # Tạm thời loại bỏ TẤT CẢ các Security Headers để kiểm tra
    # Nếu chạy được, chúng ta sẽ thêm lại từng cái một sau.

    location / {
        proxy_pass http://10.0.0.4:5601;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_cache_bypass $http_upgrade;

        # Tăng Timeout tối đa (10 phút)
        proxy_read_timeout 600;
        proxy_connect_timeout 600;
        proxy_send_timeout 600;
    }
}